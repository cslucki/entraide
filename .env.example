APP_NAME=BouclePro.com
APP_ENV=local
APP_KEY=base64:b+IwxNpzaahGTvmk+0WLnzODWBnKA99oQDutpRQ7xfI=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------------------------------------------------------
# BASE DE DONNÉES
# ---------------------------------------------------------
# Dev local : SQLite
# Prod (Laravel Cloud) : PostgreSQL 18 (variables injectées automatiquement)
DB_CONNECTION=sqlite

# ---------------------------------------------------------
# SESSION / CACHE / QUEUE
# ---------------------------------------------------------
# Dev local :
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

# Prod (Laravel Cloud) : décommenter
# SESSION_DRIVER=redis
# CACHE_STORE=redis
# QUEUE_CONNECTION=redis

SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ---------------------------------------------------------
# STOCKAGE (Laravel Cloud)
# ---------------------------------------------------------
# Sur Laravel Cloud, Object Storage est utilisé automatiquement
# Variables injectées par Laravel Cloud (ne pas modifier en local):
# AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_DEFAULT_REGION, AWS_BUCKET
# Pour configurer le bucket public spécifique:
# STORAGE_PUBLIC_DRIVER=s3
# AWS_PUBLIC_BUCKET=entraide-main-public
# AWS_PUBLIC_URL=https://xxx.s3.amazonaws.com

# ---------------------------------------------------------
# EMAILS
# ---------------------------------------------------------
# Dev : log (emails dans storage/logs/laravel.log)
MAIL_MAILER=log

# Prod (Laravel Cloud) : Resend
# MAIL_MAILER=resend
# RESEND_KEY=re_xxx
# MAIL_FROM_ADDRESS=noreply@bouclepro.com

MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@bouclepro.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
